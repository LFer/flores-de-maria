rules_version = '2';

// Flores de María — Firestore rules.
// Small trusted-team app. Authenticated users manage the business collections;
// each user may only write their own profile document.
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: anyone signed in can read; you may only write your own.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // Business data: orders, expenses, and the unified cash ledger.
    match /orders/{id}          { allow read, write: if request.auth != null; }
    match /expenses/{id}        { allow read, write: if request.auth != null; }
    match /cash_movements/{id}  { allow read, write: if request.auth != null; }
  }
}
